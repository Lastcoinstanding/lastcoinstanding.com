<script>
/* Canonical nav UX — hamburger open/close, dropdown click-toggle, click-outside, Escape, link-click close */
(function() {
  var ham = document.getElementById('hamburger');
  var mob = document.getElementById('mobileOverlay');
  var dds = document.querySelectorAll('.nav-dropdown');
  function closeMobile() {
    if (ham) ham.classList.remove('open');
    if (mob) mob.classList.remove('show');
    document.body.style.overflow = '';
  }
  function closeAllDropdowns(except) {
    for (var i = 0; i < dds.length; i++) {
      if (dds[i] !== except) dds[i].classList.remove('open');
    }
  }
  // Each dropdown's button toggles its own dropdown and closes the others.
  for (var j = 0; j < dds.length; j++) {
    (function(dd) {
      var btn = dd.querySelector('.nav-dropdown-btn');
      if (!btn) return;
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var willOpen = !dd.classList.contains('open');
        closeAllDropdowns(dd);
        dd.classList.toggle('open', willOpen);
      });
    })(dds[j]);
  }
  if (mob) {
    mob.addEventListener('click', function(e) {
      if (e.target === mob) closeMobile();
    });
    var links = mob.querySelectorAll('a');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', closeMobile);
    }
  }
  if (ham && mob) {
    ham.addEventListener('click', function() {
      var willOpen = !mob.classList.contains('show');
      ham.classList.toggle('open', willOpen);
      mob.classList.toggle('show', willOpen);
      document.body.style.overflow = willOpen ? 'hidden' : '';
    });
  }
  document.addEventListener('click', function(e) {
    // Close any dropdown whose contents the click did not land in
    for (var i = 0; i < dds.length; i++) {
      if (!dds[i].contains(e.target)) dds[i].classList.remove('open');
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeMobile(); closeAllDropdowns(); }
  });
})();

/* Footer tip address: click-to-copy with brief "copied" feedback */
(function() {
  var tipEls = document.querySelectorAll('.footer-tip-address');
  if (!tipEls.length) return;
  function copyTip(el) {
    var addr = el.getAttribute('data-tip-address');
    if (!addr) return;
    var done = function() {
      var textEl = el.querySelector('.footer-tip-text');
      if (!textEl) return;
      var orig = textEl.textContent;
      el.classList.add('copied');
      textEl.textContent = 'Copied — thank you';
      setTimeout(function() {
        textEl.textContent = orig;
        el.classList.remove('copied');
      }, 1600);
    };
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(addr).then(done).catch(function() {});
    } else {
      // Fallback for older browsers
      var ta = document.createElement('textarea');
      ta.value = addr; ta.style.position = 'fixed'; ta.style.left = '-9999px';
      document.body.appendChild(ta); ta.select();
      try { document.execCommand('copy'); done(); } catch (e) {}
      document.body.removeChild(ta);
    }
  }
  tipEls.forEach(function(el) {
    el.addEventListener('click', function() { copyTip(el); });
    el.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); copyTip(el); }
    });
  });
})();

// ═══════ Layout-level "Share this page" wiring ═══════
// Self-contained IIFE for the auto-injected .page-share section in
// base.njk. Targets [data-share-action] elements via data attributes
// (not IDs) so this coexists cleanly with any in-page share sections
// on calculator pages — those use ID-based selectors in their own
// IIFEs and don't see these handlers.
//
// URL strategy: always genericPageUrl() — origin + pathname + hash.
// Query params are intentionally stripped, since this surface is for
// page promotion (the eyebrow reads "Share this page", not "Share
// this scenario"). Calculator pages with scenario-laden Copy/Native
// buttons keep that behavior in their own in-page sections.
(function(){
  var section = document.querySelector('[data-page-share]');
  if (!section) return;

  var SHARE_TITLE = (document.title || 'Last Coin Standing').replace(/ — Last Coin Standing$/, '').replace(/ \| Last Coin Standing$/, '');

  function genericPageUrl() {
    return window.location.origin + window.location.pathname + window.location.hash;
  }

  function fallbackCopy(text) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.setAttribute('readonly', '');
    ta.style.position = 'absolute';
    ta.style.left = '-9999px';
    document.body.appendChild(ta);
    ta.select();
    var ok = false;
    try { ok = document.execCommand('copy'); } catch(e) { ok = false; }
    document.body.removeChild(ta);
    return ok;
  }

  function showCopiedFeedback(btn) {
    var labelEl = btn.querySelector('.page-share-btn-label');
    if (!labelEl) return;
    var original = labelEl.textContent;
    labelEl.textContent = 'Copied';
    btn.classList.add('copied');
    setTimeout(function(){
      labelEl.textContent = original;
      btn.classList.remove('copied');
    }, 1800);
  }

  var actions = section.querySelectorAll('[data-share-action]');
  actions.forEach(function(el){
    var action = el.getAttribute('data-share-action');

    if (action === 'copy') {
      el.addEventListener('click', function(){
        var url = genericPageUrl();
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(url).then(
            function(){ showCopiedFeedback(el); },
            function(){ if (fallbackCopy(url)) showCopiedFeedback(el); }
          );
        } else if (fallbackCopy(url)) {
          showCopiedFeedback(el);
        }
      });
      return;
    }

    if (action === 'native') {
      if (!navigator.share) return;          // keep button hidden
      el.hidden = false;
      el.addEventListener('click', function(){
        navigator.share({
          title: SHARE_TITLE,
          text: SHARE_TITLE,
          url: genericPageUrl()
        }).catch(function(){ /* user cancelled — silent */ });
      });
      return;
    }

    // Social intent buttons: rewrite href on click so the URL reflects
    // current hash (user may have changed tabs since page load).
    if (action === 'twitter' || action === 'linkedin' || action === 'facebook') {
      el.addEventListener('click', function(e){
        e.preventDefault();
        var url = genericPageUrl();
        var intentUrl;
        if (action === 'twitter') {
          intentUrl = 'https://twitter.com/intent/tweet?url=' +
            encodeURIComponent(url) + '&text=' + encodeURIComponent(SHARE_TITLE);
        } else if (action === 'linkedin') {
          intentUrl = 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(url);
        } else {
          intentUrl = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);
        }
        window.open(intentUrl, '_blank', 'noopener,noreferrer,width=620,height=540');
      });
    }
  });
})();
</script>

