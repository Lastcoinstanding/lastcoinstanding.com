<!DOCTYPE html>
<html lang="en">
<head>
{{ head_extras | safe }}
<style id="canonical-nav-css">
/* ─── Canonical nav (mobile + desktop) ─── */
/* Source of truth for site-nav, hamburger, mobile-overlay, nav-dropdown.
   Per-page CSS may override specific properties when there's a deliberate
   design reason (e.g. calc-tier pages use a different overlay style).
   Per-page rules come AFTER this block in <head> via page_styles, so they
   win by source order. */
.site-nav { display: flex; align-items: center; justify-content: space-between; padding: 12px 24px; background: rgba(10,9,8,0.95); border-bottom: 1px solid #1a1a1a; position: sticky; top: 0; z-index: 1000; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
.site-nav .brand { font-family: 'Inter', -apple-system, sans-serif; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: #999; text-decoration: none; transition: color 0.2s; }
.site-nav .brand:hover { color: #e09422; }
.site-nav .nav-links { display: flex; gap: 8px; }
.site-nav .nav-links a { font-family: 'Inter', -apple-system, sans-serif; font-size: 0.9rem; font-weight: 500; color: #aaa; text-decoration: none; padding: 8px 16px; border-radius: 4px; transition: color 0.2s, background 0.2s; }
.site-nav .nav-links a:hover { color: #ccc; background: rgba(255,255,255,0.04); }
.site-nav .nav-links a.active { color: #e09422; background: rgba(247,147,26,0.08); font-weight: 600; }
.hamburger { display: none; background: none; border: none; cursor: pointer; padding: 4px; z-index: 1100; }
.hamburger span { display: block; width: 22px; height: 2px; background: #aaa; margin: 5px 0; border-radius: 1px; transition: transform 0.3s, opacity 0.3s, background 0.3s; }
.hamburger:hover span { background: #ccc; }
.hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
.mobile-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(10,9,8,0.97); z-index: 1050; flex-direction: column; align-items: center; justify-content: flex-start; gap: 8px; opacity: 0; transition: opacity 0.3s; padding: 4.5rem 1rem 2.5rem; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.mobile-overlay.show { display: flex; opacity: 1; }
.mobile-overlay a { font-family: 'Inter', -apple-system, sans-serif; font-size: 1.1rem; font-weight: 500; color: #aaa; text-decoration: none; padding: 14px 32px; border-radius: 6px; transition: color 0.2s, background 0.2s; }
.mobile-overlay a:hover { color: #ccc; background: rgba(255,255,255,0.04); }
.mobile-overlay a.active { color: #e09422; background: rgba(247,147,26,0.08); font-weight: 600; }
.nav-dropdown { position: relative; display: inline-block; }
.nav-dropdown-btn { cursor: pointer; user-select: none; }
.nav-dropdown-menu { display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); background: rgba(10,9,8,0.97); border: 1px solid rgba(247,147,26,0.15); border-radius: 8px; padding: 8px 0; min-width: 240px; z-index: 200; backdrop-filter: blur(12px); box-shadow: 0 8px 32px rgba(0,0,0,0.4); margin-top: 0; }
.nav-dropdown:hover .nav-dropdown-menu, .nav-dropdown.open .nav-dropdown-menu { display: block; }
.nav-dropdown-menu a { display: block; padding: 9px 24px; font-size: 0.88rem; white-space: nowrap; color: #aaa; text-decoration: none; transition: color 0.2s, background 0.2s; }
.nav-dropdown-menu a:hover { color: #ccc; background: rgba(255,255,255,0.04); }
.nav-dropdown-menu a.active { color: #e09422; background: rgba(247,147,26,0.08); font-weight: 600; }
.nav-dropdown-legend { font-family: 'Inter', -apple-system, sans-serif; font-size: 0.7rem; font-style: italic; color: rgba(255,255,255,0.4); padding: 8px 24px 4px; margin-top: 4px; border-top: 1px solid rgba(255,255,255,0.06); white-space: nowrap; }
.mobile-legend { font-family: 'Inter', -apple-system, sans-serif; font-size: 0.78rem; font-style: italic; color: rgba(255,255,255,0.42); padding: 1.6rem 32px 0; margin-top: 0.6rem; border-top: 1px solid rgba(255,255,255,0.06); }
.nav-interactive-marker { color: #e09422; font-size: 0.7em; opacity: 0.7; margin-left: 2px; line-height: 1; vertical-align: 0.05em; }
.mobile-section-label { font-family: 'Inter', -apple-system, sans-serif; font-size: 0.65rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.18em; margin: 0.9rem 0 0.2rem; padding: 0 32px; }
.mobile-section-label:first-child { margin-top: 0; }
@media (max-width: 768px) {
  .site-nav .nav-links { display: none; }
  .hamburger { display: block; }
}
</style>
{%- if page_styles %}
