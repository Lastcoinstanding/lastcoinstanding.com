<script>
/* Canonical nav UX — hamburger open/close, dropdown click-toggle, click-outside, Escape, link-click close */
(function() {
  var ham = document.getElementById('hamburger');
  var mob = document.getElementById('mobileOverlay');
  var dds = document.querySelectorAll('.nav-dropdown');
  function closeMobile() {
    if (ham) ham.classList.remove('open');
    if (mob) mob.classList.remove('show');
    document.body.style.overflow = '';
  }
  function closeAllDropdowns(except) {
    for (var i = 0; i < dds.length; i++) {
      if (dds[i] !== except) dds[i].classList.remove('open');
    }
  }
  // Each dropdown's button toggles its own dropdown and closes the others.
  for (var j = 0; j < dds.length; j++) {
    (function(dd) {
      var btn = dd.querySelector('.nav-dropdown-btn');
      if (!btn) return;
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var willOpen = !dd.classList.contains('open');
        closeAllDropdowns(dd);
        dd.classList.toggle('open', willOpen);
      });
    })(dds[j]);
  }
  if (mob) {
    mob.addEventListener('click', function(e) {
      if (e.target === mob) closeMobile();
    });
    var links = mob.querySelectorAll('a');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', closeMobile);
    }
  }
  if (ham && mob) {
    ham.addEventListener('click', function() {
      var willOpen = !mob.classList.contains('show');
      ham.classList.toggle('open', willOpen);
      mob.classList.toggle('show', willOpen);
      document.body.style.overflow = willOpen ? 'hidden' : '';
    });
  }
  document.addEventListener('click', function(e) {
    // Close any dropdown whose contents the click did not land in
    for (var i = 0; i < dds.length; i++) {
      if (!dds[i].contains(e.target)) dds[i].classList.remove('open');
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeMobile(); closeAllDropdowns(); }
  });
})();
</script>

