<svg viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block">
  <line x1="8" y1="50" x2="74" y2="50" stroke="#2a2a2a" stroke-width="1"/>
  <line x1="8" y1="50" x2="8" y2="8" stroke="#2a2a2a" stroke-width="1"/>
  <!-- the trough band: where the shock lands -->
  <rect x="38" y="8" width="10" height="42" fill="#c0392b" opacity="0.10"/>
  <!-- all-in: whole stack, then a permanent step down when the shock forces a sale -->
  <path d="M 8 16 L 40 16 L 44 30 L 74 30" stroke="#F7931A" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- buffered: starts lower (the coins the buffer cost) and never steps down -->
  <path d="M 8 24 L 74 24" stroke="#6db3d4" stroke-width="2" fill="none" stroke-linecap="round"/>
  <!-- the premium: the gap the buffer paid up front -->
  <line x1="12" y1="16" x2="12" y2="24" stroke="#e09422" stroke-width="0.8" stroke-dasharray="2 2" opacity="0.7"/>
  <circle cx="8" cy="16" r="2" fill="#F7931A"/>
  <circle cx="8" cy="24" r="2" fill="#6db3d4"/>
</svg>
