<svg viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block">
  <!-- Flat coupon stream: a steady horizontal income line carrying quarterly tick marks (the distributions). -->
  <line x1="8" y1="20" x2="72" y2="20" stroke="#6db3d4" stroke-width="1.6" stroke-dasharray="5 3" opacity="0.85"/>
  <!-- Coupon tick marks -->
  <line x1="18" y1="17" x2="18" y2="23" stroke="#6db3d4" stroke-width="1.2" opacity="0.9"/>
  <line x1="32" y1="17" x2="32" y2="23" stroke="#6db3d4" stroke-width="1.2" opacity="0.9"/>
  <line x1="46" y1="17" x2="46" y2="23" stroke="#6db3d4" stroke-width="1.2" opacity="0.9"/>
  <line x1="60" y1="17" x2="60" y2="23" stroke="#6db3d4" stroke-width="1.2" opacity="0.9"/>
  <!-- Bitcoin anchor — the collateral behind the coupons -->
  <circle cx="40" cy="44" r="11" stroke="#F7931A" stroke-width="1.6" fill="rgba(247,147,26,0.10)"/>
  <text x="40" y="48.5" text-anchor="middle" fill="#F7931A" font-size="13" font-weight="700" font-family="sans-serif">&#8383;</text>
  <!-- Connection: bitcoin collateral supports the income stream above it -->
  <line x1="40" y1="33" x2="40" y2="23" stroke="#e09422" stroke-width="1" stroke-dasharray="2 2" opacity="0.55"/>
</svg>
