          <tr class="highlight-row"><td><strong>STRC under ROC (9-year hold)</strong></td><td>11.5%</td><td>Deferred, then LTCG</td><td><strong>~9% IRR</strong></td><td class="positive-yield"><strong>+2.5%</strong></td></tr>
          <tr class="highlight-row"><td><strong>SATA under ROC (8-year hold)</strong></td><td>13.0%</td><td>Deferred, then LTCG</td><td><strong>~10% IRR</strong></td><td class="positive-yield"><strong>+3.5%</strong></td></tr>
        </tbody>
