                <circle cx="34" cy="32" r="6" stroke="#F7931A" stroke-width="1.4" fill="rgba(247,147,26,0.08)"/>
                <path d="M 24 20 L 14 32 M 24 20 L 34 32 M 14 32 L 34 32" stroke="#e09422" stroke-width="0.9" opacity="0.6" stroke-dasharray="2 2"/>
                <text x="24" y="11" text-anchor="middle" fill="#F7931A" font-size="3.5" font-family="sans-serif" letter-spacing="0.5">STORE</text>
                <text x="14" y="42" text-anchor="middle" fill="#F7931A" font-size="3.5" font-family="sans-serif" letter-spacing="0.5">MOVE</text>
                <text x="34" y="42" text-anchor="middle" fill="#F7931A" font-size="3.5" font-family="sans-serif" letter-spacing="0.5">UNIT</text>
              </svg>
