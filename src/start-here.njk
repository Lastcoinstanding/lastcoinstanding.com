          <a href="/what-money-has-to-be.html" class="sh-step-link" aria-label="Begin step 1: What Money Has To Be">
            <div class="sh-step-icon">
              <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="24" cy="14" r="6" stroke="#F7931A" stroke-width="1.4" fill="rgba(247,147,26,0.08)"/>
