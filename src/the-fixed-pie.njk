<div class="page">
  <!-- PAGE HEADER -->
  <header class="page-header">
    <h1>The Bitcoin <span class="amber">Fixed</span> Share</h1>
    <p class="subtitle">Your share of the Bitcoin network is mathematically fixed at the moment of acquisition - and nothing can change that. Watch how that compares to every other form of money.</p>
  </header>

  <!-- TABS -->
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="slice">
      <span class="tab-num">Part I</span>
      <span class="tab-title">The Bitcoin Fixed Share</span>
    </button>
