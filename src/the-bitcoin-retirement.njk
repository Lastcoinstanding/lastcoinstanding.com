  <!-- TAB 4: THE MATH -->
  <!-- ═══════════════════════════════════════════ -->
  <div class="tab-content" id="tab-math">
    <div class="construction-note">
      <p><strong>Coming soon.</strong> The Math tab will document the projection mechanics, withdrawal-rate framework, escape-velocity threshold, and the modeling assumptions that drive the calculator.</p>
    </div>
  </div>

  {% include 'components/related.njk' %}
